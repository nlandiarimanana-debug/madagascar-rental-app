# Server
PORT=5000
NODE_ENV=development

# Database
DB_TYPE=mongodb
DB_HOST=localhost
DB_PORT=27017
DB_NAME=madagascar_rental
DB_USER=
DB_PASSWORD=
MONGODB_URI=mongodb://localhost:27017/madagascar_rental
POSTGRES_URI=postgresql://user:password@localhost:5432/madagascar_rental

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRE=7d

# File Upload
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,gif
UPLOAD_DIR=./uploads

# Cloud Storage (Optional)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
AWS_S3_BUCKET=

# Email Service
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@madagascarrental.com

# Google Maps
GOOGLE_MAPS_API_KEY=

# Mapbox (Alternative)
MAPBOX_TOKEN=

# Payment (Stripe)
STRIPE_SECRET_KEY=
STRIPE_PUBLIC_KEY=

# Frontend URL
FRONTEND_URL=http://localhost:3000
